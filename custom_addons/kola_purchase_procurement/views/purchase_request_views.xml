<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_request_list" model="ir.ui.view">
        <field name="name">purchase.request.list</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <list string="Purchase Requests">
                <field name="name"/>
                <field name="requester_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="request_date"/>
                <field name="needed_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" groups="purchase.group_purchase_user" invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object" string="Reject" groups="purchase.group_purchase_user" invisible="state not in ('submitted', 'approved')"/>
                    <button name="action_create_rfq" type="object" string="Create RFQ" class="oe_highlight" groups="purchase.group_purchase_user" invisible="state != 'approved'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="state not in ('submitted', 'rejected')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rfq_created"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_rfq"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not rfq_id">
                            <div class="o_field_statinfo">
                                <span class="o_stat_text">RFQ</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label">Purchase Request</span>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="requester_id"/>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="needed_date" readonly="state not in ('draft', 'submitted')"/>
                            <field name="vendor_ids" widget="many2many_tags" readonly="state in ('rfq_created', 'rejected')"/>
                            <field name="rfq_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products" name="products">
                            <field name="line_ids" readonly="state not in ('draft', 'submitted')">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="estimated_price"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1" readonly="state in ('rfq_created', 'rejected')"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_purchase_request_search" model="ir.ui.view">
        <field name="name">purchase.request.search</field>
        <field name="model">purchase.request</field>
        <field name="arch" type="xml">
            <search string="Purchase Requests">
                <field name="name"/>
                <field name="requester_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter name="my_requests" string="My Requests" domain="[('requester_id', '=', uid)]"/>
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter name="group_state" string="Status" domain="[]" context="{'group_by': 'state'}"/>
                    <filter name="group_department" string="Department" domain="[]" context="{'group_by': 'department_id'}"/>
                    <filter name="group_requester" string="Requester" domain="[]" context="{'group_by': 'requester_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form,activity</field>
        <field name="search_view_id" ref="view_purchase_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a purchase request.
            </p>
            <p>
                Employees use purchase requests to ask Procurement to prepare an RFQ.
            </p>
        </field>
    </record>

    <menuitem id="menu_purchase_request"
              name="Purchase Requests"
              parent="purchase.menu_procurement_management"
              action="action_purchase_request"
              sequence="1"/>
</odoo>
